# WeChat Official Account Credentials
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# Enterprise WeChat Robot Webhook
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key

# 可选：AI 测试资讯专属企微机器人地址
WECOM_QA_BOT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_qa_key

# Optional: Proxy/News API Keys
# OPENAI_API_KEY=...

# Dify AI Service (For Translation & Summarization)
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=your_dify_api_key
DIFY_USER_ID=user_123

# 测试平台专用 Dify 配置
TEST_PLATFORM_DIFY_API_KEY=your_test_platform_dify_api_key
TEST_PLATFORM_DIFY_USER_ID=lifeng16527

# Dify 限流重试策略
DIFY_RATE_LIMIT_MAX_RETRIES=5
DIFY_RATE_LIMIT_BASE_DELAY_SECONDS=2
DIFY_RATE_LIMIT_MAX_DELAY_SECONDS=30
DIFY_RATE_LIMIT_COOLDOWN_SECONDS=20

# 大模型上下文预算（GPT-5.4 默认值；如切换 GPT-5.2，可将窗口改为 400000）
LLM_CONTEXT_WINDOW_TOKENS=1050000
LLM_RESERVED_OUTPUT_TOKENS=128000
LLM_RESERVED_PROMPT_TOKENS=32000
LLM_MAX_PROMPT_INPUT_TOKENS=60000
LLM_TOKENIZER_ENCODING=o200k_base
