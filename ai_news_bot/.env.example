# 微信公众号凭证
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 企业微信机器人 Webhook
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_wecom_key

# Dify LLM 配置
DIFY_API_BASE=https://dify.cvte.com/v1
DIFY_API_KEY=your_dify_api_key
DIFY_USER_ID=your_user_id

# 飞书应用凭证
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_FOLDER_TOKEN=your_folder_token

# WeCom Bot Webhook URL for Feishu Doc links
WECOM_BOT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_wecom_bot_key
